{
  "name": "create-next-log",
  "version": "0.1.0",
  "description": "CLI scaffolder for personal blogs powered by Next.js and MDX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/geonsang-jo/create-next-log"
  },
  "keywords": [
    "blog",
    "nextjs",
    "mdx",
    "cli",
    "scaffolder",
    "starter"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-template.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "chalk": "4.1.2",
    "fs-extra": "11.3.4",
    "prompts": "2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/prompts": "2.4.9",
    "typescript": "5.9.3"
  }
}
